   "source": [
    "# **Q12.Compute f(x) = x^3 + 2x^2 - 5x + 1.**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "0128804d",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "f(5) = 5³ + 2×5² - 5×5 + 1 = 151\n"
     ]
    }
   ],
   "source": [
    "def f(x):\n",
    "  result = x**3 + 2*x**2 - 5*x + 1\n",
    "  return result\n",
    "\n",
    "x = int(input(\"Enter a value of x: \"))\n",
    "\n",
    "y = f(x)\n",
    "print(f\"f({x}) = {x}³ + 2×{x}² - 5×{x} + 1 = {y}\")"
   ]
  }
 ],
